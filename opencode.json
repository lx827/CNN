{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "server-filesystem": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "D:\\code\\CNN"
            ],
            "timeout": 100000,
            "enabled": true
        },
        "server-git": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-git",
                "D:\\code\\CNN"
            ],
            "timeout": 10000,
            "enabled": true
        },
        "server-puppeteer": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-puppeteer"
            ],
            "environment": {
                "PUPPETEER_DOWNLOAD_HOST": "https://npmmirror.com/mirrors"
            },
            "timeout": 30000,
            "enabled": true
        }
    }
}